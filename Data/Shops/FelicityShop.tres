[sub_resource type="Resource" id="ShopItemData_nikuman"]
script = ExtResource("2_shop_item")
item_data = ExtResource("5_nikuman")
shop_tab_id = &"foods"
price_override = 120

[sub_resource type="Resource" id="ShopItemData_white_rice"]
script = ExtResource("2_shop_item")
item_data = ExtResource("6_white_rice")
shop_tab_id = &"foods"
price_override = 80

[sub_resource type="Resource" id="ShopItemData_oolong_tea"]
script = ExtResource("2_shop_item")
item_data = ExtResource("7_oolong_tea")
shop_tab_id = &"drinks"
price_override = 80

[sub_resource type="Resource" id="ShopItemData_water_bottle"]
script = ExtResource("2_shop_item")
item_data = ExtResource("8_water_bottle")
shop_tab_id = &"drinks"
price_override = 50

[sub_resource type="Resource" id="ShopTabData_foods"]
script = ExtResource("3_shop_tab")
tab_id = &"foods"
display_name = "食品"

[sub_resource type="Resource" id="ShopTabData_drinks"]
script = ExtResource("3_shop_tab")
tab_id = &"drinks"
display_name = "飲料"

[resource]
script = ExtResource("1_shop_data")
shop_id = &"felicity"
display_name = "Felicity"
description = "デカダンスの中心街に灯る安息のバー。グリムの料理、マスターの気配り、仲間たちの温もりが集まる帰る場所。"
portrait = ExtResource("6_f8oiv")
sticker = ExtResource("4_felicity_sticker")
shop_bgm = ExtResource("8_d32om")
tabs = Array[ExtResource("3_shop_tab")]([SubResource("ShopTabData_foods"), SubResource("ShopTabData_drinks")])
items = Array[ExtResource("2_shop_item")]([SubResource("ShopItemData_nikuman"), SubResource("ShopItemData_white_rice"), SubResource("ShopItemData_oolong_tea"), SubResource("ShopItemData_water_bottle")])
