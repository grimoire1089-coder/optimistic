[resource]
script = ExtResource("1_shop_data")
shop_id = &"yuzhou_xingdeng"
display_name = "星灯小館"
description = "ユージョウが切り盛りする、ネオン路地裏の小さな中華飯店。温かい料理と茶で、少しだけ心の重力を軽くしてくれる。"
portrait = ExtResource("4_yuzhou_portrait")
sticker = ExtResource("5_shop_sticker")
shop_bgm = ExtResource("13_yuzhou_bgm")
tabs = Array[ExtResource("3_shop_tab")]([SubResource("ShopTabData_foods"), SubResource("ShopTabData_drinks"), SubResource("ShopTabData_recipes")])
items = Array[ExtResource("2_shop_item")]([SubResource("ShopItemData_nikuman"), SubResource("ShopItemData_congee"), SubResource("ShopItemData_xiaolongbao"), SubResource("ShopItemData_sesame_dango"), SubResource("ShopItemData_starlight_cake"), SubResource("ShopItemData_lychee_soda"), SubResource("ShopItemData_oolong_tea"), SubResource("ShopItemData_congee_recipe"), SubResource("ShopItemData_xiaolongbao_recipe")])
