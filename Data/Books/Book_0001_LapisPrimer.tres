[resource]
script = ExtResource("1_book_data")
book_id = &"book_0001_lapis_primer"
display_name = "ラピス入門"
description = "スマート端末ラピスの基本操作をまとめた電子書籍。"
author_name = "デカダンス生活局"
body_text = "ラピスは通信、決済、魔導操作をひとつにまとめたスマート端末です。\n\n手首や耳元、胸部装甲に埋め込む型が一般的で、意識や声に反応してホログラム画面を展開します。\n\n日常ではメッセージ、支払い、予定管理、娯楽閲覧に使われます。慣れてきたら魔法回路の簡易操作や、ミラージュジェムとの連携にも挑戦できます。"
icon = ExtResource("2_lapis_icon")
genre_id = &"guide"
genre_display_name = "ガイド"
buy_price = 120
